{
  "name": "procezly",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @procezly/web",
    "dev:web": "npm run dev -w @procezly/web",
    "dev:api": "npm run dev -w @procezly/api",
    "build": "npm run build -w @procezly/web && npm run build -w @procezly/api",
    "lint": "npm run lint -w @procezly/web"
  }
}